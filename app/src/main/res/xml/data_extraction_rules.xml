<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include DB and DataStore. Android 9+ encrypts backups before upload. -->
        <include domain="database" path="family_home.db" />
        <include domain="file" path="datastore" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="family_home.db" />
    </device-transfer>
</data-extraction-rules>
